DATABASE_URL=sqlite:///./dev.db
# Railway Postgres: paste referenced DATABASE_URL as-is (postgres://...); the app adds the psycopg driver.
JWT_SECRET=dev-secret-change-me
INTERNAL_JOB_TOKEN=dev-internal-token

# Demo seeding (optional)
SEED_DEMO_DATA=true
SEED_ADMIN_PASSWORD=password1

ENV=dev
API_TITLE=Fuel Books API
API_VERSION=0.1.0

# Postgres local example:
# DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/fuelbooks

# --- Account management / email -------------------------------------------
# Used to build links inside outbound emails (reset, verify, change email).
FRONTEND_BASE_URL=http://localhost:3000

# Email: "console" = log only; "resend" = https://resend.com (set RESEND_API_KEY).
EMAIL_PROVIDER=console
# Required when EMAIL_PROVIDER=resend — never commit real keys.
RESEND_API_KEY=
# Must match an allowed sender in Resend. Until your domain is verified, use:
#   EMAIL_FROM=onboarding@resend.dev
# (Resend may only deliver test sends to your account email — see their docs.)
EMAIL_FROM=Fuel Books <onboarding@resend.dev>

# Single-use token TTLs.
PASSWORD_RESET_TTL_MINUTES=30
EMAIL_VERIFY_TTL_HOURS=24

# Brute-force lockout on /login.
MAX_FAILED_LOGINS=5
LOCKOUT_MINUTES=15
